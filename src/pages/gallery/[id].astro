---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

import Lightbox from '../../components/Lightbox.astro';

export async function getStaticPaths() {
  const albums = await getCollection("album");

  return albums.map((album: CollectionEntry<"album">) => {
    const cleanId = album.id.split('/')[0];
    
    return {
      params: { id: cleanId },
      props: { album },
    };
  });
}

interface Props {
  album: CollectionEntry<"album">;
}

const { album } = Astro.props as Props;
const albumId = album.id.split('/')[0];
const base = import.meta.env.BASE_URL;

const allImages = import.meta.glob<{ default: ImageMetadata }>("/src/content/albums/**/*.{jpeg,jpg}");

const imagePromises = Object.entries(allImages)
  .filter(([path]) => path.includes(`/src/content/albums/${albumId}/`))
  .map(([_, resolver]) => resolver().then((mod) => mod.default));

const images = await Promise.all(imagePromises);
---

<!doctype html>
<html lang="en">
  <BaseLayout title={`${album.data.title} | ${SITE_TITLE}`} description={album.data.description || SITE_DESCRIPTION}>
    <div class="text-center my-16 mb-32">
      <h1 class="text-3xl xl:text-6xl font-bold">
        {album.data.title}
      </h1>
      {album.data.description && (
        <p class="text-lg xl:text-2xl my-4">
          {album.data.description}
        </p>
      )}
    
      <div class="flex justify-center my-8">
        <div id="gallery" class="max-w-[95vw] px-4 columns-1 sm:columns-2 md:columns-3 lg:columns-4 xl:columns-5 2xl:columns-6 3xl:columns-8 gap-4">
          {images.map((img, index) => (
            <a 
            href={img.src} 
            data-pswp-width={img.width} 
            data-pswp-height={img.height} 
            target="_blank"
            class="inline-block mb-4"
            >
              <Image
                src={img}
                alt={`Image from ${album.data.title} album`}
                layout="constrained"
                quality="mid"
                sizes="(max-width: 640px) 100vw,
                        (max-width: 768px) 50vw,
                        (max-width: 1024px) 33vw,
                        (max-width: 1280px) 25vw,
                        (max-width: 1536px) 20vw,
                        (max-width: 1920px) 16.6vw,
                        12.5vw"
                class="rounded-sm mb-4 w-full h-auto border border-transparent hover:border-gray-300 transition-all duration-300 ease-in-out hover:shadow-lg inline-block"
                loading={index < 2 ? "eager" : "lazy"}
                fetchpriority={index < 2 ? "high" : "auto"}
              />
            </a>
          ))}
        </div>
      </div>
    
      <p class="text-lg my-4 text-center">
        <a href={`${base}/gallery/`} class="text-gray-400 hover:text-white hover:underline transition-colors"
          >← Go back</a
        >
      </p>
    </div>
    <Lightbox />
  </BaseLayout>
</html>