---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PhotoCard from '../components/PhotoCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;

const images = import.meta.glob<{ default: ImageMetadata }>([
  '/src/content/blog/**/*.{jpeg,jpg,png,gif}',
  '/src/assets/**/*.{jpeg,jpg,png,gif}'
]);

const photos = [
  {
    src: "/src/content/blog/2025-12-sri-lanka/elephant_truck.jpg",
    alt: "Elephant and Truck",
    caption: "Elephant & Truck"
  },
  {
    src: "/src/content/blog/2025-07-alps/grindelwald_panorama.jpg",
    alt: "Grindelwald Panorama",
    caption: "Grindelwald Panorama"
  },
  {
    src: "/src/assets/blog-placeholder-about.jpg",
    alt: "Placeholder About",
    caption: "Placeholder About"
  },
  {
    src: "/src/assets/blog-placeholder-1.jpg",
    alt: "Placeholder 1",
    caption: "Placeholder 1"
  }
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-4xl font-bold">
				My Photography Blog!
			</h1>
			<p>
				This website is a work in progress. So far I am hoping to add some of my favourite photos and stories from my travels.
			</p>
			<p>
				Here is an <a href={`${base}/blog/2025-12-sri-lanka/`}>Elephant</a> 🐘 to keep you company while you wait!
			</p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {photos.map((photo, index) => {
					if (!images[photo.src]) {
						throw new Error(`"${photo.src}" does not exist in glob: "src/content/blog/**" or "src/assets/**"`);
					}
					return (
						<PhotoCard 
							imagePath={images[photo.src]()}
							alt={photo.alt} 
							caption={photo.caption}
							/* If it's one of the first 3 images, load it immediately */
							loading={index < 3 ? "eager" : "lazy"}
      						fetchpriority={index < 3 ? "high" : "auto"}
						/>
					);
                })}
            </div>
        </div>
		</main>
		<Footer />
	</body>
</html>
