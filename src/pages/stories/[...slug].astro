---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Story from '../../layouts/Story.astro';

export async function getStaticPaths() {
    const posts = await getCollection('stories');
    return posts.map((post: CollectionEntry<'story'>) => {
        const slug = post.id.replace(/\/index$/, '').replace(/\.(md|mdx)$/, '');
        
        return {
            params: { slug: slug }, 
            props: post,
        };
    });
}
type Props = CollectionEntry<'story'>;

const post = Astro.props;
const { Content } = await render(post);
---

<Story {...post.data}>
	<Content />
</Story>
