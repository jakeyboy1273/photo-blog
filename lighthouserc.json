{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run preview",
      "url": [
        "http://localhost:4321/photo-blog",
        "http://localhost:4321/photo-blog/blog",
        "http://localhost:4321/photo-blog/blog/2025-12-sri-lanka",
        "http://localhost:4321/photo-blog/gallery",
        "http://localhost:4321/photo-blog/gallery/2025-04-cairngorms"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.98 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }]
      }
    }
  }
}
