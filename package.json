    "lighthouse": "astro build && lhci collect && lhci assert",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.6",
    "photoswipe": "^5.4.4",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.5",
    "typescript-eslint": "^8.57.1"
  },
  "overrides": {
    "vite": "7.3.1"
  }
